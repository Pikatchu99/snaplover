# Copier sur le VPS vers ~/snaplover/web.env, remplir les vraies valeurs.
# Jamais committé (voir .gitignore). Ces variables sont lues à l'EXÉCUTION
# par la route /api/turn-credentials — contrairement aux NEXT_PUBLIC_* (site
# URL, signaling URL, Umami), qui sont figées au BUILD de l'image Docker
# (--build-arg, voir .github/workflows/deploy-web.yml) et n'ont pas besoin
# d'être répétées ici.

STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

TURN_URLS=turn:standard.relay.metered.ca:80

# Option A — creds statiques Metered (au démarrage, avant rotation éventuelle)
TURN_USERNAME=
TURN_CREDENTIAL=

# Option B — creds éphémères (TURN REST), prioritaire si définie
TURN_SECRET=

# Quota Metered (optionnel) — lu par /api/turn-status pour bloquer la
# création de room une fois l'usage gratuit du mois atteint. Les 3 requises
# ensemble pour activer le check. METERED_SECRET_KEY = clé API du dashboard
# Metered (différente de TURN_USERNAME/TURN_CREDENTIAL ci-dessus).
METERED_APP_NAME=
METERED_SECRET_KEY=
METERED_FREE_QUOTA_GB=
