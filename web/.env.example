# URL absolue du site en prod — utilisée pour metadataBase/canonical/OG/
# sitemap (voir CLAUDE.md "Aucune valeur d'infra en dur"). Déploiement de
# référence de ce projet :
NEXT_PUBLIC_SITE_URL=https://snaplover.hbdwall.xyz

# URL du service de signaling (WebSocket)
NEXT_PUBLIC_SIGNALING_URL=wss://signaling.tondomaine.com

# STUN — pas de secret ici (service public), mais reste configurable via env
# comme toute adresse d'infra. Valeur usuelle : STUN public Google.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN — exposés uniquement via /api/turn-credentials, jamais NEXT_PUBLIC (§11 spec)
# Open Relay (gratuit) : https://www.metered.ca/tools/openrelay/
TURN_URLS=turn:turn.tondomaine.com:3478,turns:turn.tondomaine.com:5349

# Option A — creds statiques (offres gratuites type Metered/ExpressTURN au démarrage)
TURN_USERNAME=
TURN_CREDENTIAL=

# Option B — creds éphémères (TURN REST), prioritaire si définie : ignore USERNAME/CREDENTIAL ci-dessus
TURN_SECRET=

# Analytics (Umami auto-hébergé) — optionnel, laisser vide pour désactiver le tracking
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
